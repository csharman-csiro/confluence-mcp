# Confluence MCP Server Configuration (Server / Data Center)
# Copy this file to .env and fill in your actual values

# Your Confluence base URL, including any reverse-proxy context path
# (without trailing slash), e.g. https://confluence.internal.example.com
# or https://confluence.internal.example.com/confluence
CONFLUENCE_BASE_URL=https://confluence.your-internal-domain.com

# Personal Access Token: Confluence -> Profile picture -> Settings ->
# Personal Access Tokens -> Create token. Scope it to the spaces below.
CONFLUENCE_API_TOKEN=your-personal-access-token-here

# Comma-separated list of space keys you want to allow access to
ALLOWED_SPACES=SPACE1,SPACE2,SPACE3

# Enable debug logging (optional)
DEBUG=false